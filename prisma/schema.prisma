// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CrmRole {
  ADMIN
  VENDEDOR
}

model CrmUser {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  role         CrmRole
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assignedLeads ContactForm[] @relation("LeadAssignee")
  updatedLeads ContactForm[] @relation("LeadUpdater")
  sessions     CrmSession[]

  @@index([role])
}

model CrmSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      CrmUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ContactForm {
  id                String   @id @default(cuid())
  nombre            String
  negocio           String
  provincia         String
  localidad         String
  cantidad          String
  etapa             String   // etapa original del formulario
  etapaCrm          String   @default("entrante") // etapa del CRM: entrante, primer-llamado, seguimiento, ganado, perdido
  primerLlamadoAt   DateTime? // cuando pasó de entrante a primer-llamado (para métricas)
  whatsapp          String
  cuit              String?  // CUIT opcional
  email             String?
  comentarios       String?
  notas             String?  // notas del CRM
  valor             Float?   // valor estimado del lead
  assignedToId      String?
  updatedByUserId   String?
  esBajoVolumen     Boolean  @default(false) // marca si es un lead de bajo volumen (menos de 24 docenas)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  assignedTo        CrmUser? @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  updatedByUser     CrmUser? @relation("LeadUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([esBajoVolumen])
  @@index([etapaCrm])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([updatedByUserId])
  @@index([esBajoVolumen, etapaCrm])
  @@index([esBajoVolumen, createdAt])
  @@map("contact_forms")
}
